{
  "name": "ling-chat",
  "private": false,
  "version": "0.4.7",
  "type": "module",
  "scripts": {
    "init": "tauri icon src-tauri/icons/icon.png && node scripts/prepare-desktop-resources.mjs && node scripts/download_emotion_model.mjs",
    "dev": "vite",
    "build": "vue-tsc --noEmit --skipLibCheck && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "android:prepare": "tauri android init && node scripts/generate-android-icons.mjs",
    "android:dev": "tauri android dev",
    "android:build": "node scripts/prepare-bundled-resources.mjs 9 && tauri android build --target aarch64"
  },
  "dependencies": {
    "7zip-min": "^3.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "axios": "^1.16.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.0",
    "tauri-plugin-screenshots-api": "file:./src-tauri/plugins/tauri-plugin-screenshots",
    "vue": "^3.5.13",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.7.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-classnames": "^0.10.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^2.1.10"
  }
}
