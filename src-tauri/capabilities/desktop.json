{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop",
  "description": "Desktop-only capabilities (updater and process plugins are not available on mobile)",
  "windows": ["main", "settings"],
  "platforms": ["windows", "linux", "macOS"],
  "permissions": [
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart"
  ]
}
